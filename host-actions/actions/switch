#!/bin/sh
# switch - switch container to different image tag
set -e

CONTAINER="${1?Usage: switch <container> <from_tag> [to_tag]}"
FROM_TAG="${2?Usage: switch <container> <from_tag> [to_tag]}"
TO_TAG="${3:-current}"
DOCKER_CMD="${DOCKER_CMD:-docker}"
BASE_IMAGE="${BASE_IMAGE:-localhost/goclaw}"

FROM_IMAGE="${BASE_IMAGE}:${FROM_TAG}"
$DOCKER_CMD image inspect "$FROM_IMAGE" || { echo "Image not found: $FROM_IMAGE"; exit 1; }

CURRENT=$($DOCKER_CMD inspect --format='{{.Config.Image}}' "$CONTAINER")
TARGET="${BASE_IMAGE}:${TO_TAG}"

if [ "$TO_TAG" = "current" ]; then
    $DOCKER_CMD tag "$CURRENT" "${BASE_IMAGE}:previous"
fi
$DOCKER_CMD tag "$FROM_IMAGE" "$TARGET"
