#!/bin/sh
# commit - commit a podman container, keeping previous as backup
set -e

CONTAINER="${1?Usage: commit <container> [tag]}"
TAG="${2:-current}"
DOCKER_CMD="${DOCKER_CMD:-docker}"
BASE_IMAGE="${BASE_IMAGE:-localhost/goclaw}"

CURRENT_IMAGE="${BASE_IMAGE}:${TAG}"
PREVIOUS="${BASE_IMAGE}:previous"

$DOCKER_CMD image inspect "$CURRENT_IMAGE" >/dev/null 2>&1 && \
    $DOCKER_CMD tag "$CURRENT_IMAGE" "$PREVIOUS" || true

$DOCKER_CMD commit "$CONTAINER" "$CURRENT_IMAGE"
